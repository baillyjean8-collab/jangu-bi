# ════════════════════════════════════════════════════════
# JANGU BI — Environment Variables
# Copy this file to .env and fill in all values.
# NEVER commit .env to version control.
# ════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────
NODE_ENV=development          # development | production | test
PORT=5000

# ── Server public URL (used for webhook notify_url) ─────────
SERVER_URL=https://api.jangubi.com

# ── Client (CORS whitelist) ───────────────────────────────
# The frontend URL — only this origin is allowed to call the API
CLIENT_URL=http://localhost:5173

# ── MongoDB ───────────────────────────────────────────────
# Get this from MongoDB Atlas → Connect → Drivers
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/jangubi?retryWrites=true&w=majority

# ── JWT Secrets ───────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# MUST be at least 32 characters. MUST be different from each other.
JWT_ACCESS_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING_FOR_ACCESS_TOKEN
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_HEX_STRING_FOR_REFRESH

# Token lifetimes
JWT_ACCESS_EXPIRES_IN=15m     # 15 minutes — short lived
JWT_REFRESH_EXPIRES_IN=7d     # 7 days — rotated on use

# ── OTP ───────────────────────────────────────────────────
# Used as HMAC-SHA256 key for OTP hashing (replaces bcrypt for OTPs)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# MUST be at least 32 characters.
OTP_HMAC_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING_FOR_OTP_HASHING

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes (in milliseconds)
RATE_LIMIT_MAX_REQUESTS=100   # General API: 100 req per window
AUTH_RATE_LIMIT_MAX=10        # Auth endpoints: 10 req per window

# ── Payment Providers ─────────────────────────────────────
# CinetPay — https://cinetpay.com
CINETPAY_API_KEY=
CINETPAY_SITE_ID=

# Wave — https://wave.com/en/business
WAVE_SECRET_KEY=

# Orange Money
ORANGE_MONEY_SECRET=

# MTN Mobile Money
MTN_MOMO_SECRET=

# ════════════════════════════════════════════════════════
# PRODUCTION CHECKLIST (before going live)
# ════════════════════════════════════════════════════════
# [ ] NODE_ENV=production
# [ ] CLIENT_URL set to real frontend domain (HTTPS)
# [ ] MONGODB_URI using Atlas production cluster
# [ ] JWT_ACCESS_SECRET and JWT_REFRESH_SECRET are different, 64+ chars
# [ ] OTP_HMAC_SECRET is 64+ chars, stored in secrets manager
# [ ] All payment secrets filled in
# [ ] Secrets stored in AWS Secrets Manager / Render Secrets / Vault
# [ ] No secrets in code or Git history
# ════════════════════════════════════════════════════════
