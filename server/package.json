{
  "name": "jangu-bi-server",
  "version": "1.0.0",
  "description": "JANGU BI — Secure digital religious platform API",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon -r dotenv/config server.js",
    "lint": "eslint src/ --ext .js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "seed": "node scripts/seed.js",
    "seed:reset": "node scripts/seed.js --reset"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "@tabler/icons-webfont": "^3.44.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.11.1",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "multer": "^2.2.0",
    "rate-limit-redis": "^4.3.1",
    "socket.io": "^4.6.2",
    "validator": "^13.11.0",
    "livekit-server-sdk": "^2.9.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "eslint-plugin-security": "^4.0.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/src/__tests__/**/*.test.js",
      "**/shared/payment/__tests__/**/*.test.js"
    ],
    "testTimeout": 30000,
    "forceExit": true,
    "verbose": true
  }
}
